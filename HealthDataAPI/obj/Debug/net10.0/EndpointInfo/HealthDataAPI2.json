{
  "openapi": "3.1.1",
  "info": {
    "title": "HealthDataAPI2 | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7112"
    },
    {
      "url": "http://localhost:5295"
    }
  ],
  "paths": {
    "/api/HealthData/send": {
      "post": {
        "tags": [
          "HealthData"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HealthDataDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/HealthDataDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/HealthDataDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/HealthData/latest": {
      "get": {
        "tags": [
          "HealthData"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/HealthData/history": {
      "get": {
        "tags": [
          "HealthData"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthDataDto": {
        "type": "object",
        "properties": {
          "temp": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "float"
          },
          "hr": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "spo2": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "time": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "HealthData"
    }
  ]
}