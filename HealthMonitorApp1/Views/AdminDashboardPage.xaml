<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthMonitorApp1.Views.AdminDashboardPage"
             Title="Admin Dashboard"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="10">
            <Frame CornerRadius="15"
                   BackgroundColor="#E74C3C"
                   Padding="15">
                <VerticalStackLayout Spacing="5">
                    <Label Text="👑 ADMIN DASHBOARD"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Quản lý dữ liệu sức khỏe người dùng"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Thống kê -->
                <Frame CornerRadius="15"
                       BackgroundColor="White"
                       Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📊 THỐNG KÊ"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"/>
                        <Label x:Name="StatsLabel"
                               Text="Đang tải..."
                               FontSize="14"
                               TextColor="#666"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Danh sách user -->
                <Frame CornerRadius="15"
                       BackgroundColor="White"
                       Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="👥 DANH SÁCH NGƯỜI DÙNG"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"/>

                        <CollectionView x:Name="UsersCollectionView"
                                        SelectionMode="Single"
                                        SelectionChanged="UserSelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="10"
                                          ColumnDefinitions="Auto,*,Auto">
                                        <Label Grid.Column="0"
                                               Text="👤"
                                               FontSize="20"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Username}"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding LastLogin}"
                                               FontSize="12"
                                               TextColor="#999"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Dữ liệu của user được chọn -->
                <Frame x:Name="UserDataFrame"
                       CornerRadius="15"
                       BackgroundColor="White"
                       Padding="15"
                       IsVisible="False">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="SelectedUserLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#4A90E2"/>

                        <Label Text="📋 LỊCH SỬ ĐO GẦN ĐÂY"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#666"/>

                        <CollectionView x:Name="HistoryCollectionView"
                                        HeightRequest="300">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame CornerRadius="10"
                                           BackgroundColor="#F5F5F5"
                                           Padding="10"
                                           Margin="0,5">
                                        <VerticalStackLayout Spacing="8">

                                            <!-- Dòng 1: Thời gian -->
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="🕐" FontSize="12"/>
                                                <Label Text="{Binding FormattedTime}" FontSize="12" TextColor="#666"/>
                                            </HorizontalStackLayout>

                                            <!-- Dòng 2: 3 chỉ số -->
                                            <Grid ColumnSpacing="15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Nhiệt độ -->
                                                <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                                    <Label Text="🌡️" FontSize="12"/>
                                                    <Label Text="{Binding FormattedTemperature}" FontSize="12" TextColor="#E74C3C"/>
                                                </HorizontalStackLayout>

                                                <!-- Nhịp tim -->
                                                <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                                    <Label Text="❤️" FontSize="12"/>
                                                    <Label Text="{Binding FormattedHeartRate}" FontSize="12" TextColor="#E67E22"/>
                                                </HorizontalStackLayout>

                                                <!-- SpO2 -->
                                                <HorizontalStackLayout Grid.Column="2" Spacing="5">
                                                    <Label Text="🫁" FontSize="12"/>
                                                    <Label Text="{Binding FormattedSpO2}" FontSize="12" TextColor="{Binding SpO2Color}"/>
                                                </HorizontalStackLayout>
                                            </Grid>

                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Khung gửi gợi ý cho user đã chọn -->
                <Frame x:Name="SuggestionFrame"
                       CornerRadius="15"
                       BackgroundColor="White"
                       Padding="15"
                       IsVisible="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="💬 GỬI GỢI Ý CHO NGƯỜI DÙNG"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#4A90E2"/>

                        <Entry x:Name="SuggestionEntry"
                               Placeholder="Nhập lời khuyên, gợi ý sức khỏe..."
                               BackgroundColor="#F5F5F5"/>

                        <Button Text="GỬI GỢI Ý"
                                BackgroundColor="#27AE60"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="40"
                                Clicked="SendSuggestionButton_Clicked"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Nút đăng xuất - Đã chuyển xuống cuối cùng -->
                <Button Text="ĐĂNG XUẤT"
                        BackgroundColor="#E74C3C"
                        TextColor="White"
                        CornerRadius="25"
                        HeightRequest="45"
                        Clicked="LogoutButton_Clicked"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>